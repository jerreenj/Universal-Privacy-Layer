# ─── Dependencies ────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
venv/
env/
.venv/

# ─── Build outputs ───────────────────────────────────────────────
frontend/build/
*.tsbuildinfo

# ─── ZK circuit build artifacts (generated, 7MB — don't bloat git) ──
# The zkey + wasm are produced by the circom + snarkjs toolchain under
# contracts/circuits/build/. The backend copies them to
# backend/zk_artifacts/ at deploy time (see scripts/sync_zk_artifacts.sh).
contracts/circuits/build/
backend/zk_artifacts/

# ─── Environment & secrets — NEVER commit ───────────────────────
.env
.env.*
*.env
backend/.env
frontend/.env
*.pem
*.key
*.p12
*.pfx
credentials.json
.credentials
.credential
mnemonic.txt
seed.txt
# Local-only credentials file (keep a template, never the real one)
memory/test_credentials.local.md

# ─── Deployment internals ───────────────────────────────────────
# NOTE: the Sui Move package under contracts/sui/ IS committed (sources +
# tests + Move.toml) — that is the whole point of making Sui real & visible
# to the Sui grants review (the prior `contracts/sui/` blanket-ignore was the
# exact reason the language bar showed 0% Move). We ignore only build/ test
# artifacts + the real deploy manifest (the .example template stays tracked).
contracts/deployed_*.json
contracts/verifier_addresses.json
contracts/deploy*.py
contracts/sui/build/
contracts/sui/dependency_constr.lock
contracts/sui/.sui/
scripts/deployed_sui_mainnet.json

# ─── Solana deploy keypair (P2.10 Step C.3) ─────────────────────
# The program deploy keypair IS the upgrade authority. It is preserved locally
# so devnet + mainnet share one program ID (one-shot mainnet, no rewrite), but
# it must NEVER be committed — committing it exposes the upgrade authority.
scripts/.upl_sol-deploy-keypair.json
scripts/deployed_sol_devnet.json
scripts/deployed_sol_mainnet.json

# ─── PrivacyRelayer hot wallet (Gap 6 closer round) ─────────────
# Dedicated hot wallet that fronts gas for PrivacyRelayer.relayAndAnnounce.
# The deployer rotated ownership to this wallet via setRelayer (tx
# 0x225c781e…); committing it would let anyone drain the relayer buffer
# or impersonate the PrivacyRelayer's authorised caller.
scripts/.relayer-hot-wallet.txt
scripts/.relayer-hot-wallet.json

# ─── Logs & test artifacts ──────────────────────────────────────
*.log
logs/
test_reports/
*.xml
backend_test*

# ─── Database dumps (never commit production data) ─────────────
*.tgz
dump/
upl_database/

# ─── Editor / OS ─────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
# Windows reserved-name artifact (e.g. `nul` from a redirected command);
# harmless but should never be tracked.
nul

# ─── Platform & caches ───────────────────────────────────────────
.emergent/
.ruff_cache/
.cache/
frontend/node_modules/.cache/
