# ─── Dependencies ────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
venv/
env/
.venv/

# ─── Build outputs ───────────────────────────────────────────────
frontend/build/
*.tsbuildinfo

# ─── Environment & secrets — NEVER commit ───────────────────────
.env
.env.*
*.env
backend/.env
frontend/.env
*.pem
*.key
*.p12
*.pfx
credentials.json
.credentials
.credential
mnemonic.txt
seed.txt
# Local-only credentials file (keep a template, never the real one)
memory/test_credentials.local.md

# ─── Deployment internals ───────────────────────────────────────
# NOTE: the Sui Move package under contracts/sui/ IS committed (sources +
# tests + Move.toml) — that is the whole point of making Sui real & visible
# to the Sui grants review (the prior `contracts/sui/` blanket-ignore was the
# exact reason the language bar showed 0% Move). We ignore only build/ test
# artifacts + the real deploy manifest (the .example template stays tracked).
contracts/deployed_*.json
contracts/verifier_addresses.json
contracts/deploy*.py
contracts/sui/build/
contracts/sui/dependency_constr.lock
contracts/sui/.sui/
scripts/deployed_sui_mainnet.json

# ─── Logs & test artifacts ──────────────────────────────────────
*.log
logs/
test_reports/
*.xml
backend_test*

# ─── Database dumps (never commit production data) ─────────────
*.tgz
dump/
upl_database/

# ─── Editor / OS ─────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp

# ─── Platform & caches ───────────────────────────────────────────
.emergent/
.ruff_cache/
.cache/
frontend/node_modules/.cache/
