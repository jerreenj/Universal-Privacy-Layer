{
  "name": "upl-zkp-circuits",
  "version": "1.0.0",
  "description": "ZKP circuits for Universal Privacy Layer",
  "scripts": {
    "build": "./build_circuits.sh",
    "compile:stealth": "circom sources/stealth_ownership.circom --r1cs --wasm --sym -o build -l node_modules",
    "compile:amount": "circom sources/amount_range.circom --r1cs --wasm --sym -o build -l node_modules",
    "compile:membership": "circom sources/membership.circom --r1cs --wasm --sym -o build -l node_modules"
  },
  "dependencies": {
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.4"
  },
  "keywords": ["zkp", "circom", "snarkjs", "privacy", "ethereum"],
  "license": "MIT"
}
